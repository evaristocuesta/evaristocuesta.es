@model evaristocuesta.es.Models.PageViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>@Model.Title</title>
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />
    <!-- Font Awesome icons (free version)-->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <!-- Google fonts-->
    <link href="https://fonts.googleapis.com/css?family=Varela+Round" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet" />
    <!-- Bootstrap 5.2.3-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/evaristocuesta.es.styles.css" asp-append-version="true" />
</head>
<body id="page-top" class="@(Model.HasHeroImage ? "" : "no-hero")">
    <!-- Navigation-->
    <nav class="navbar navbar-expand-lg navbar-light fixed-top @(Model.HasHeroImage ? "" : "navbar-solid")" id="mainNav">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand" title="Evaristo Cuesta Fotografía fotos fotógrafo">
                <img src="~/favicon.ico" alt="Logo" class="navbar-brand-icon" />
                EVARISTO CUESTA
            </a>
            <button class="navbar-toggler navbar-toggler-right" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="~/" title="Evaristo Cuesta Fotografía fotos fotógrafo">Inicio</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="~/galeria-fotos"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false"
                           title="Galería de Fotos Evaristo Cuesta Fotografía Fotógrafo">Galería Fotos</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="~/galeria-fotos" title="Galería de Fotos Evaristo Cuesta Fotografía Fotógrafo">Galería de fotos</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="~/paisajes-naturaleza" title="Paisajes naturaleza fotografía">Paisajes de Naturaleza</a></li>
                            <li><a class="dropdown-item" href="~/fotografia-nocturna" title="nocturnas fotografía larga exposición">Fotografía Nocturna</a></li>
                            <li><a class="dropdown-item" href="~/paisajes-urbanos" title="Paisajes urbanos fotografía">Fotografía Urbana</a></li>
                            <li><a class="dropdown-item" href="~/retratos-books-moda" title="Retratos books moda fotografía sevilla">Books y Retratos</a></li>
                            <li><a class="dropdown-item" href="~/reportaje-bodas" title="Reportajes de Boda Sevilla Fotógrafo Fotografía">Reportajes de Boda</a></li>
                            <li><a class="dropdown-item" href="~/conciertos" title="Reportajes de Conciertos Fotógrafo Fotografía Sevilla">Reportajes de Conciertos</a></li>
                            <li><a class="dropdown-item" href="~/reportaje-fotos-embarazadas" title="fotógrafo embarazadas sevilla reportaje embarazadas">Reportajes de Embarazos</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="~/venta-fotografias" title="Venta de Fotos Evaristo Cuesta Fotografía Fotógrafo">Venta Fotos</a></li>
                    <li class="nav-item"><a class="nav-link" href="~/contacto" title="Contacto Evaristo Cuesta Fotografía Fotógrafo Fotos">Contacto</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    @await Html.PartialAsync("_Footer")

    <!-- Lightbox Modal (Global) -->
    <div id="lightbox" class="lightbox" style="display: none;">
        <div class="lightbox-content">
            <button class="lightbox-close" aria-label="Cerrar">&times;</button>
            <button class="lightbox-prev" aria-label="Anterior">‹</button>
            <button class="lightbox-next" aria-label="Siguiente">›</button>
            <img id="lightbox-image" src="" alt="" class="lightbox-image" />
            <div class="lightbox-title" id="lightbox-title"></div>
            <div class="lightbox-counter">
                <span id="lightbox-current">1</span> / <span id="lightbox-total">1</span>
            </div>
        </div>
    </div>

    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="~/js/site.js"></script>
    <script src="~/js/banner-cookies.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <!-- Gallery Lightbox JS (loaded after Scripts section to ensure galleryData is available) -->
    <script src="~/js/gallery-lightbox.js"></script>
    @await Html.PartialAsync("_CookiesBanner")
</body>
</html>
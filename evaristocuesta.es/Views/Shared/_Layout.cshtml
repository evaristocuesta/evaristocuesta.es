@model evaristocuesta.es.ViewModels.PageViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>@Model.Title</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />
    <!-- Font Awesome icons (free version)-->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <!-- Google fonts-->
    <link href="https://fonts.googleapis.com/css?family=Varela+Round" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet" />
    <!-- Bootstrap 5.2.3-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Core theme CSS (includes Bootstrap)-->
    <link href="css/site.css" rel="stylesheet" />
</head>
<body id="page-top">
    <!-- Navigation-->
    <nav class="navbar navbar-expand-lg navbar-light fixed-top" id="mainNav">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand" href="#page-top">evaristocuesta.es</a>
            <button class="navbar-toggler navbar-toggler-right" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="/galeria-fotos" role="button" data-bs-toggle="dropdown" aria-expanded="false">Galería Fotos</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/galeria-fotos">Galería de fotos</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/paisajes-naturaleza">Paisajes de Naturaleza</a></li>
                            <li><a class="dropdown-item" href="/fotografia-nocturna">Fotografía Nocturna</a></li>
                            <li><a class="dropdown-item" href="/paisajes-urbanos">Fotografía Urbana</a></li>
                            <li><a class="dropdown-item" href="/retratos-books-moda">Books y Retratos</a></li>
                            <li><a class="dropdown-item" href="/reportaje-bodas">Reportajes de Boda</a></li>
                            <li><a class="dropdown-item" href="/conciertos">Reportajes de Conciertos</a></li>
                            <li><a class="dropdown-item" href="/reportaje-fotos-embarazadas">Reportajes de Embarazos</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/venta-fotografias">Venta Fotos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <!-- Footer-->
    <footer class="footer small text-center text-white-50"><div class="container px-4 px-lg-5">Copyright &copy; evaristocuesta.es 2026</div></footer>
    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="js/site.js"></script>
</body>
</html>
@model PhotoGalleryViewModel

<div class="container py-5">
    <div class="row">
        <div class="col-12 text-center mb-4">
            <h1>@Model.H1</h1>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol itemscope itemtype="https://schema.org/BreadcrumbList" class="breadcrumb">
                    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="breadcrumb-item">
                        <a itemprop="item" href="/" title="Evaristo Cuesta Fotografía">
                            <span itemprop="name">Inicio</span>
                        </a>
                        <meta itemprop="position" content="1">
                    </li>
                    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="breadcrumb-item">
                        <a itemprop="item" href="/galeria-fotos" title="Galería de fotos">
                            <span itemprop="name">Galería</span>
                        </a>
                        <meta itemprop="position" content="2">
                    </li>
                    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="breadcrumb-item active" aria-current="page">
                        <span itemprop="name">@Model.H1</span>
                        <meta itemprop="position" content="3">
                    </li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="photo-gallery-grid">
        @foreach (var item in Model.GaleriaItems)
        {
            <a data-gallery="@Model.GalleryId" 
               href="@item.Image" 
               title="@item.Title"
               class="gallery-grid-item">
                <img src="@item.Image" alt="@item.Alt" title="@item.Title" class="gallery-grid-image" loading="lazy" />
                <div class="gallery-grid-overlay">
                    <span class="gallery-grid-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
                </div>
            </a>
        }
    </div>
</div>